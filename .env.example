# ---- Paperless-ngx ----
PAPERLESS_URL=https://paperless.deinedomain.de
PAPERLESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Tag-Steuerung ----
# Dokumente mit diesem Tag werden gesendet, danach auf SENT umgetaggt.
FINOM_PENDING_TAG=finom-pending
FINOM_SENT_TAG=finom-sent
FINOM_ERROR_TAG=finom-error

# ---- Optionale Zusatzfilter (leer = ignorieren) ----
FINOM_CORRESPONDENT_ID=
FINOM_DOCUMENT_TYPE_ID=
FINOM_CREATED_AFTER=
FINOM_CREATED_BEFORE=

# Original-Datei statt Archiv-PDF/A senden (Finom will meist das Original):
FINOM_PREFER_ORIGINAL=true

# ---- Dateiname ----
# Leer lassen -> Paperless' formatierter Name wird genutzt.
# Platzhalter: {title} {created} {correspondent} {doc_id} {ext}
FINOM_FILENAME_TEMPLATE=
FINOM_FILENAME_SOURCE= # template, original, service, media

# ---- Finom Import-Adresse ----
FINOM_INBOX_EMAIL=deine-import-adresse@finom.co

# ---- SMTP (Versand an Finom) ----
SMTP_HOST=smtp.tomorrow.one
SMTP_PORT=587
SMTP_USER=deinabsender@navilalabs.de
SMTP_PASSWORD=xxxxxxxx
SMTP_FROM=deinabsender@navilalabs.de
SMTP_STARTTLS=true

# ---- Lokale Audit-DB ----
FINOM_DB_PATH=/data/finom_sync.sqlite3

# ---- Sicherheit ----
FINOM_MAX_PER_RUN=0          # 0 = unbegrenzt; z.B. 10 zum Testen
FINOM_DRY_RUN=false

# ---- Optionaler HTTP-Trigger ----
FINOM_TRIGGER_TOKEN=         # setzen, wenn du `serve` nutzt
